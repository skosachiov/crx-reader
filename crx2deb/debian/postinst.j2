#!/bin/sh
set -e

# Ensure directory exists
mkdir -p "$(dirname {{ policies_file }})"

# Initialize empty JSON if needed
if [ ! -s {{ policies_file }} ]; then
    echo '{}' > {{ policies_file }}
fi

# Validate or recreate if corrupted
if ! jq empty {{ policies_file }} 2>/dev/null; then
    echo '{}' > {{ policies_file }}
fi

ENTRY="{{ crx_id }};file:///{{ extension_dir }}/{{ crx_name }}.crx"

# Check if entry already exists
if ! jq --arg entry "$ENTRY" \
       '.ExtensionInstallForcelist // [] | index($entry)' \
       {{ policies_file }} | grep -q true; then
    # Add the entry
    jq --arg entry "$ENTRY" \
       '.ExtensionInstallForcelist = (.ExtensionInstallForcelist // []) + [$entry]' \
       {{ policies_file }} > {{ policies_file }}.tmp && \
    mv {{ policies_file }}.tmp {{ policies_file }}
fi

exit 0
